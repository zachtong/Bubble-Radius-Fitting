/* ============================================================
   Bubble Radius Fitting  —  Figma-inspired QSS theme
   Colour palette from CLAUDE.md design spec
   ============================================================ */

/* ---------- Global ---------- */
* {
    font-family: "Segoe UI", "Helvetica Neue", sans-serif;
    font-size: 12px;
    color: #334155;
}

QMainWindow {
    background: #F8FAFC;
}

/* ---------- Dark bars (header / status) ---------- */
QWidget#HeaderBar {
    background: #0F172A;
    border-bottom: 1px solid #1E293B;
    min-height: 44px;
    max-height: 44px;
}
QWidget#HeaderBar QLabel {
    color: #F1F5F9;
    font-weight: bold;
    font-size: 14px;
}
QWidget#HeaderBar QPushButton {
    background: transparent;
    color: #94A3B8;
    border: none;
    padding: 4px 10px;
    border-radius: 4px;
}
QWidget#HeaderBar QPushButton:hover {
    background: #1E293B;
    color: #F1F5F9;
}

QWidget#StatusBar {
    background: #0F172A;
    border-top: 1px solid #1E293B;
    min-height: 28px;
    max-height: 28px;
}
QWidget#StatusBar QLabel {
    color: #94A3B8;
    font-size: 11px;
}

/* ---------- Left panel ---------- */
QWidget#LeftPanel {
    background: #FFFFFF;
    border-right: 1px solid #E2E8F0;
}

/* ---------- Cards ---------- */
QGroupBox {
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    margin-top: 8px;
    padding: 14px 12px 12px 12px;
    font-weight: bold;
    font-size: 12px;
    color: #334155;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 2px 8px;
}

/* ---------- Buttons ---------- */
QPushButton {
    background: #2563EB;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 6px 16px;
    font-weight: 600;
    min-height: 28px;
}
QPushButton:hover {
    background: #1D4ED8;
}
QPushButton:pressed {
    background: #1E40AF;
}
QPushButton:disabled {
    background: #CBD5E1;
    color: #94A3B8;
}
QPushButton#secondaryBtn {
    background: #F1F5F9;
    color: #334155;
    border: 1px solid #E2E8F0;
}
QPushButton#secondaryBtn:hover {
    background: #E2E8F0;
}
QPushButton#dangerBtn {
    background: #EF4444;
}
QPushButton#dangerBtn:hover {
    background: #DC2626;
}
QPushButton#successBtn {
    background: #22C55E;
}

/* ---------- Sliders ---------- */
QSlider::groove:horizontal {
    height: 6px;
    background: #E2E8F0;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    width: 16px;
    height: 16px;
    margin: -5px 0;
    background: white;
    border: 2px solid #3B82F6;
    border-radius: 8px;
}
QSlider::sub-page:horizontal {
    background: #3B82F6;
    border-radius: 3px;
}

/* ---------- Spin boxes / Line edits ---------- */
QSpinBox, QDoubleSpinBox, QLineEdit {
    border: 1px solid #CBD5E1;
    border-radius: 6px;
    padding: 4px 8px;
    background: white;
    min-height: 24px;
}

/* ---------- Check boxes ---------- */
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #CBD5E1;
    border-radius: 4px;
    background: white;
}
QCheckBox::indicator:checked {
    background: #3B82F6;
    border-color: #3B82F6;
    image: none;
}

/* ---------- Tab bar ---------- */
QWidget#TabBar QPushButton {
    background: transparent;
    color: #64748B;
    border: none;
    border-bottom: 2px solid transparent;
    border-radius: 0;
    padding: 8px 16px;
    font-weight: 600;
}
QWidget#TabBar QPushButton:checked,
QWidget#TabBar QPushButton[active="true"] {
    color: #2563EB;
    border-bottom: 2px solid #2563EB;
}

/* ---------- Scroll area ---------- */
QScrollArea {
    border: none;
    background: transparent;
}
QScrollBar:vertical {
    width: 6px;
    background: transparent;
}
QScrollBar::handle:vertical {
    background: #CBD5E1;
    border-radius: 3px;
    min-height: 20px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

/* ---------- Progress bar ---------- */
QProgressBar {
    border: none;
    background: #E2E8F0;
    border-radius: 4px;
    height: 8px;
    text-align: center;
    font-size: 0;
}
QProgressBar::chunk {
    background: #3B82F6;
    border-radius: 4px;
}

/* ---------- Labels ---------- */
QLabel#sectionTitle {
    font-weight: bold;
    font-size: 13px;
    color: #1E293B;
}
QLabel#dimText {
    color: #94A3B8;
    font-size: 11px;
}

/* ---------- Collapsible header ---------- */
QPushButton#collapseToggle {
    background: transparent;
    color: #334155;
    border: none;
    border-bottom: 1px solid #E2E8F0;
    border-radius: 0;
    text-align: left;
    padding: 8px 4px;
    font-weight: bold;
}

/* ---------- Sidebar toggle ---------- */
QPushButton#sidebarToggle {
    background: #F1F5F9;
    border: 1px solid #E2E8F0;
    border-radius: 0;
    min-width: 20px;
    max-width: 20px;
    color: #64748B;
    font-size: 10px;
}
QPushButton#sidebarToggle:hover {
    background: #E2E8F0;
}
